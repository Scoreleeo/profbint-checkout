generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Purchase {
  id              String   @id @default(cuid())
  stripeSessionId String   @unique
  stripePaymentId String?
  productName     String
  amount          Int
  currency        String   @default("gbp")
  status          String
  createdAt       DateTime @default(now())
}